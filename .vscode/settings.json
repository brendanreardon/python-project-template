{
  // Editor
  "breadcrumbs.enabled": true,
  "explorer.compactFolders": false,
  "editor.guides.indentation": true,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.rulers": [88],

  // Formatting & linting
  "editor.defaultFormatter": "charliermarsh.ruff",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.ruff": "always",
    "source.organizeImports.ruff": "always"
  },
  "files.trimTrailingWhitespace": true,
  "markdownlint.config": {
    "MD024": false,
    "MD041": false,
  },

  // Jupyter notebooks
  "jupyter.askForKernelRestart": false,
  "jupyter.interactiveWindow.creationMode": "perFile",

  // Python & environments
  // Set python.defaultInterpreterPath locally
  // Run conda env create -f environment.yaml and then select the interpreter in VS Code
  "python.analysis.typeCheckingMode": "basic",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python-envs.defaultEnvManager": "ms-python.python:conda",
  "python-envs.defaultPackageManager": "ms-python.python:conda",

  // pyproject.toml
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
  },
  "evenBetterToml.formatter.arrayAutoCollapse": false,
  "evenBetterToml.formatter.arrayAutoExpand": false,
  "evenBetterToml.formatter.indentTables": false,
  "evenBetterToml.formatter.indentString": "  ",

  // Testing UI
  "testing.automaticallyOpenPeekView": "never",

  // Terminal
  "terminal.integrated.environmentChangesRelaunch": true,
}
